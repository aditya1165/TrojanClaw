# FastAPI app settings
APP_NAME=TrojanClaw API
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true

# Supabase settings
# Find these in your Supabase project settings:
# - Project URL: Settings > API > URL
# - anon key/service role key: Settings > API > Project API keys
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-api-key
